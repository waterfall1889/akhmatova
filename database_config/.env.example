# Copy to ".env" and adjust. For shells: set -a; source .env; set +a
# Spring Boot maps these names when passed as OS environment variables.

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=changeme

# Optional
# APP_AUTH_FRONTEND_LOGIN_URL=http://localhost:5173/login
# APP_AUTH_ALLOW_LEGACY_PLAINTEXT=false
