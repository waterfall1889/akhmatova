# Copy to "database.properties" (gitignored). Loaded by backend via spring.config.import.
# Run the backend with working directory = backend/ so ../database_config resolves correctly.

spring.datasource.url=jdbc:postgresql://localhost:5432/postgres
spring.datasource.username=postgres
spring.datasource.password=changeme

# MongoDB（头像等）
spring.data.mongodb.uri=mongodb://localhost:27017/akhmatova

